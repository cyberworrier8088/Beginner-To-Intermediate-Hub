# ========================================
# EXCEPTIONS (FILES TO KEEP)
# ========================================
# Keep important configuration files
!.gitignore
!README.md
!CONTRIBUTING.md
!LICENSE
!requirements.txt
!Cargo.toml
!Makefile

# Keep example files that are part of learning
!examples/
!tutorials/
!docs/

# Keep test files that are part of repository
!test_*/
!tests/

